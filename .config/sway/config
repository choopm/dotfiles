# keymap
input * {
    xkb_layout de,de
    xkb_options grp:alt_shift_toggle
}
# settings
set $mod Mod4
set $Alt Mod1
set $mod2 Mod4+Control
set $terminal urxvtc -pe tabbed
set $terminal-floating urxvtc -pe tabbed -title !F!
set $screensaver swaylock -i $wallpaper
set $rofi_param -threads 4 -m -4 -no-parse-known-hosts
set $wallpaper /home/choopm/Dokumente/Wallpaper/eye.png
set $status_command py3status -c ~/.config/sway/status-bottom.conf
set $Mon_LVDS LVDS1
set $Mon_Left HDMI3
set $Mon_Right HDMI2
floating_modifier $mod
font pango:Liberation Sans 9
workspace_auto_back_and_forth yes
focus_follows_mouse yes
mouse_warping output

#workspaces
set $ws1 "1: "
set $ws2 "2: "
set $ws3 "3: "
set $ws4 "4: "
set $ws5 "5: "
set $ws6 "6: "
set $ws7 7
set $ws8 8
set $ws9 9
set $ws10 10
set $ws11 11
set $ws12 12
set $ws13 13
set $ws14 14
set $ws15 15
set $ws16 16
set $ws16 "16: "
set $ws17 17
set $ws18 18
set $ws19 19
set $ws20 20
set $ws21 21
set $ws22 22
set $wsvpn vpn
#workspace $ws1 output $Mon_LVDS
workspace $ws2 output $Mon_Left
workspace $ws3 output $Mon_Right
#workspace $ws4 output $Mon_LVDS
workspace $ws5 output $Mon_LVDS
workspace $ws16 output $Mon_Right

# autoruns
exec urxvtd -q -f -o
exec mako
output "*" bg $wallpaper fill

# monitor config at work
output "Unknown HP 24o CNK7061KW8" transform 270 pos 0,0
output "Unknown HP 24o CNK71002CY" pos 1080,440
# LVDS
output "Unknown 0x573D 0x00000000" pos 3000,440
# monitor config at home
output "Unknown ZOWIE XL LCD EAG01008SL0" pos 4920,440

# start / kill
bindsym $mod+Return exec $terminal
bindsym $mod+KP_Enter exec $terminal
bindsym $mod+Control+Return exec $terminal-floating
bindsym $mod+Control+KP_Enter exec $terminal-floating
bindsym $mod+Shift+Return exec $terminal-floating
bindsym $mod+Shift+KP_Enter exec $terminal-floating
bindsym $mod+c kill

# launchers
bindsym $mod+r exec --no-startup-id rofi $rofi_param -show "combi"
bindsym $mod+p exec --no-startup-id rofi-pass
bindsym $mod+q exec --no-startup-id /home/choopm/.scripts/rofi_notes.sh
bindsym --release Print exec --no-startup-id ~/.scripts/wayland-scrot.sh
bindsym --release Shift+Print exec --no-startup-id ~/.scripts/wayland-scrot.sh slurp

bindsym XF86AudioPlay exec --no-startup-id mpc --host 0pointer.org toggle
bindsym XF86AudioNext exec --no-startup-id mpc --host 0pointer.org next; exec --no-startup-id killall -USR1 py3status
bindsym XF86AudioPrev exec --no-startup-id mpc --host 0pointer.org prev; exec --no-startup-id killall -USR1 py3status

bindsym XF86AudioLowerVolume exec --no-startup-id amixer --quiet set Master 5%-; exec --no-startup-id killall -USR1 py3status
bindsym Shift+XF86AudioLowerVolume exec --no-startup-id amixer --quiet set Master 15%-; exec --no-startup-id killall -USR1 py3status
bindsym $mod+Control+F4 exec --no-startup-id amixer --quiet set Master 5%-; exec --no-startup-id killall -USR1 py3status

bindsym XF86AudioRaiseVolume exec --no-startup-id amixer --quiet set Master 5%+; exec --no-startup-id killall -USR1 py3status
bindsym Shift+XF86AudioRaiseVolume exec --no-startup-id amixer --quiet set Master 15%+; exec --no-startup-id killall -USR1 py3status
bindsym $mod+Control+F5 exec --no-startup-id amixer --quiet set Master 5%+; exec --no-startup-id killall -USR1 py3status

bindsym XF86AudioMute exec --no-startup-id amixer --quiet set Master toggle; exec --no-startup-id killall -USR1 py3status
bindsym Shift+XF86AudioMute exec --no-startup-id amixer --quiet set Master 100%; exec --no-startup-id killall -USR1 py3status
bindsym XF86AudioMicMute exec --no-startup-id amixer --quiet set Capture toggle

bindsym XF86MonBrightnessUp           exec --no-startup-id brightnessctl set 10%+
bindsym Control+F9                    exec --no-startup-id brightnessctl set 10%+
bindsym $mod+XF86MonBrightnessUp      exec --no-startup-id brightnessctl set 100%
bindsym $mod+Control+F9               exec --no-startup-id brightnessctl set 100%
bindsym XF86MonBrightnessDown         exec --no-startup-id brightnessctl set 10%-
bindsym Control+F8                    exec --no-startup-id brightnessctl set 10%-
bindsym $mod+XF86MonBrightnessDown    exec --no-startup-id brightnessctl set 0%
bindsym $mod+Control+F8               exec --no-startup-id brightnessctl set 0%

bindsym XF86ScreenSaver exec --no-startup-id $screensaver
bindsym $mod+Scroll_Lock exec --no-startup-id $screensaver
bindsym XF86Display exec --no-startup-id /home/choopm/.scripts/togglebl.sh
bindsym XF86Launch1 exec --no-startup-id icecat; exec --no-startup-id thunderbird; exec --no-startup-id pidgin; exec --no-startup-id quasselclient; exec --no-startup-id teamspeak3
bindsym Scroll_Lock exec --no-startup-id icecat; exec --no-startup-id thunderbird; exec --no-startup-id pidgin; exec --no-startup-id quasselclient; exec --no-startup-id teamspeak3

bindsym $mod+o exec --no-startup-id rofi $rofi_param -show "window"
bindsym $mod+udiaeresis exec --no-startup-id /home/choopm/.scripts/rofi-monitor.sh
bindsym $mod+Control+p exec --no-startup-id /home/choopm/.scripts/imgurup.sh
bindsym $mod+Control+s exec --no-startup-id /home/choopm/.scripts/imgurdown.sh
bindsym $mod+Control+v exec --no-startup-id /home/choopm/.scripts/rofi-vpn.sh
bindsym $mod+Control+space exec --no-startup-id /home/choopm/.scripts/toggletouchpad.sh

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+u [urgent=latest] focus
bindsym $mod+a focus parent
bindsym $mod+d focus child
bindsym $mod+Escape workspace back_and_forth
bindsym $mod+Tab workspace back_and_forth

# mark window
bindsym $mod+Shift+m mode $mode_mark_window
bindsym $mod+Shift+g mode $mode_goto_window
bindsym $mod+Shift+comma mode $mode_goto_window
bindsym $mod+Control+m exec i3-input -F 'mark %s' -P 'Mark as: '
bindsym $mod+Control+g exec i3-input -F '[con_mark=%s] focus' -P 'Goto mark: '
bindsym $mod+comma exec i3-input -F '[con_mark=%s] focus' -P 'Goto mark: '

# rename workspace
bindsym $mod+$Alt+n exec i3-input -F 'rename workspace to "%s"' -P 'Rename workspace to: '

# rename window
bindsym $mod+Control+n exec i3-input -F 'title_format "<b>[%s]</b>   %title"' -P 'Window [tag]: '

# create new workspace
bindsym $mod+g exec --no-startup-id rofi $rofi_param -show "Goto/Create workspace"

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left 100
bindsym $mod+Shift+Down move down 100
bindsym $mod+Shift+Up move up 100
bindsym $mod+Shift+Right move right 100
bindsym $mod+n move scratchpad
bindsym $mod+Shift+n scratchpad show
bindsym $mod+Shift+Escape move container to workspace back_and_forth; workspace back_and_forth
bindsym $mod+Shift+Tab move container to workspace back_and_forth; workspace back_and_forth

bindsym $mod+Control+Next move workspace to output right
bindsym $mod+Control+Prior move workspace to output left

bindsym $mod+Shift+Control+h move workspace to output left
bindsym $mod+Shift+Control+l move workspace to output right
bindsym $mod+Shift+Control+k move workspace to output up
bindsym $mod+Shift+Control+j move workspace to output down
bindsym $mod+Shift+Control+Left move workspace to output left
bindsym $mod+Shift+Control+Right move workspace to output right
bindsym $mod+Shift+Control+Up move workspace to output up
bindsym $mod+Shift+Control+Down move workspace to output down

bindsym $mod+Control+h focus output left
bindsym $mod+Control+l focus output right
bindsym $mod+Control+k focus output up
bindsym $mod+Control+j focus output down
bindsym $mod+Control+Left focus output left
bindsym $mod+Control+Right focus output right
bindsym $mod+Control+Up focus output up
bindsym $mod+Control+Down focus output down

# next splits
bindsym $mod+z split h
bindsym $mod+v split v

# layouts
bindsym $mod+f fullscreen
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# floating
