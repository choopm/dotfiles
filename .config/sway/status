order += "frame infos"
frame infos {
    format = "{output}{button}"
    format_separator = ' '
    format_button_closed = "  "
    format_button_open = " "
    open = false

    uname {
        color = 'FF00FF'
        format = " {release}"
    }

    diskdata root {
        cache_timeout = 900
        disk = "/dev/mapper/root"
        unit = G
        format = " / {used_percent}% {used}{unit}"
        on_click 1 = "exec $terminal -e ranger; refresh"
    }

    diskdata boot {
        cache_timeout = 900
        disk = "nvme0n1p1"
        unit = G
        format = " /boot {used_percent}% {used}{unit}"
        on_click 1 = "exec $terminal -e ranger; refresh"
    }
}

