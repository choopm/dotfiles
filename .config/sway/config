# keymap
input * {
    xkb_layout "de"
    xkb_options ""
    xkb_variant "neo"
    tap enabled
    natural_scroll disabled
}
input 1133:49970:Logitech_Gaming_Mouse_G502 {
    pointer_accel 1
}

set $Mon_LVDS Unknown 0x573D 0x00000000
bindswitch --reload --locked lid:on output $Mon_LVDS disable
bindswitch --reload --locked lid:off output $Mon_LVDS enable

# monitor config at work
#output "Unknown HP 24o CNK7061KW8" transform 270 pos 0,0
#output "Unknown HP 24o CNK71002CY" pos 1080,440
# LVDS
output "Unknown 0x573D 0x00000000" pos 0,0
# monitor config at home office
output "BenQ Corporation ZOWIE XL LCD EAG01008SL0" pos 1920,0

# settings
set $mod Mod4
set $Alt Mod1
set $mod2 Mod4+Control
set $terminal termite
set $terminal-floating termite --title !F!
set $screensaver swaylock -i $wallpaper
set $rofi_param -threads 4 -m -4 -no-parse-known-hosts
set $wallpaper /home/choopm/Syncthing/Bilder/Wallpaper/eye.png
set $status_command py3status -c ~/.config/sway/status-bottom.conf
floating_modifier $mod
font pango:Liberation Sans 9
workspace_auto_back_and_forth yes
focus_follows_mouse yes
mouse_warping output

#workspaces
set $ws1 "1: "
set $ws2 "2: "
set $ws3 "3: "
set $ws4 "4: "
set $ws5 "5: "
set $ws6 "6: "
set $ws7 7
set $ws8 8
set $ws9 9
set $ws10 10
set $ws11 11
set $ws12 12
set $ws13 13
set $ws14 14
set $ws15 15
set $ws16 16
set $ws16 "16: "
set $ws17 17
set $ws18 18
set $ws19 19
set $ws20 20
set $ws21 21
set $ws22 "22: "
set $wsvpn vpn

# autoruns
exec mako
output "*" bg $wallpaper fill

# start / kill
bindsym $mod+Return exec $terminal
bindsym $mod+KP_Enter exec $terminal
bindsym $mod+Control+Return exec $terminal-floating
bindsym $mod+Control+KP_Enter exec $terminal-floating
bindsym $mod+Shift+Return exec $terminal-floating
bindsym $mod+Shift+KP_Enter exec $terminal-floating
bindsym $mod+adiaeresis kill

# launchers
bindsym $mod+c exec rofi $rofi_param -show "combi"
bindsym $mod+q exec rofi-pass
bindsym $mod+x exec /home/choopm/.scripts/rofi_notes.sh
bindsym --release Print exec ~/.scripts/wayland-scrot.sh
bindsym --release Shift+Print exec ~/.scripts/wayland-scrot.sh slurp

bindsym XF86AudioPlay exec mpc --host 0pointer.org toggle
bindsym XF86AudioNext exec mpc --host 0pointer.org next; exec killall -USR1 py3status
bindsym XF86AudioPrev exec mpc --host 0pointer.org prev; exec killall -USR1 py3status

bindsym XF86AudioLowerVolume exec amixer --quiet set Master 5%-; exec killall -USR1 py3status
bindsym Shift+XF86AudioLowerVolume exec amixer --quiet set Master 15%-; exec killall -USR1 py3status
bindsym $mod+Control+F4 exec amixer --quiet set Master 5%-; exec killall -USR1 py3status

bindsym XF86AudioRaiseVolume exec amixer --quiet set Master 5%+; exec killall -USR1 py3status
bindsym Shift+XF86AudioRaiseVolume exec amixer --quiet set Master 15%+; exec killall -USR1 py3status
bindsym $mod+Control+F5 exec amixer --quiet set Master 5%+; exec killall -USR1 py3status

bindsym XF86AudioMute exec amixer --quiet set Master toggle; exec killall -USR1 py3status
bindsym Shift+XF86AudioMute exec amixer --quiet set Master 100%; exec killall -USR1 py3status
bindsym XF86AudioMicMute exec amixer --quiet set Capture toggle

bindsym XF86MonBrightnessUp           exec brightnessctl set 10%+
bindsym Control+F9                    exec brightnessctl set 10%+
bindsym $mod+XF86MonBrightnessUp      exec brightnessctl set 100%
bindsym $mod+Control+F9               exec brightnessctl set 100%
bindsym XF86MonBrightnessDown         exec brightnessctl set 10%-
bindsym Control+F8                    exec brightnessctl set 10%-
bindsym $mod+XF86MonBrightnessDown    exec brightnessctl set 0%
bindsym $mod+Control+F8               exec brightnessctl set 0%

bindsym XF86ScreenSaver exec $screensaver
bindsym $mod+Scroll_Lock exec $screensaver
bindsym XF86Display exec /home/choopm/.scripts/togglebl.sh
bindsym XF86Launch1 exec icecat; exec thunderbird; exec pidgin; exec quasselclient; exec teamspeak3
bindsym Scroll_Lock exec icecat; exec thunderbird; exec pidgin; exec quasselclient; exec teamspeak3

bindsym $mod+o exec rofi $rofi_param -show "Goto/Create workspace"
bindsym $mod+ssharp exec /home/choopm/.scripts/rofi-monitor.sh
bindsym $mod+Control+q exec /home/choopm/.scripts/imgurup.sh
bindsym $mod+Control+i exec /home/choopm/.scripts/imgurdown.sh
bindsym $mod+Control+p exec /home/choopm/.scripts/rofi-vpn.sh
bindsym $mod+Control+space exec /home/choopm/.scripts/toggletouchpad.sh

# change focus
bindsym $mod+s focus left
bindsym $mod+n focus down
bindsym $mod+r focus up
bindsym $mod+t focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+h [urgent=latest] focus
bindsym $mod+u focus parent
bindsym $mod+a focus child
bindsym $mod+Escape workspace back_and_forth
bindsym $mod+Tab workspace back_and_forth

# mark window
bindsym $mod+Shift+m mode $mode_mark_window
bindsym $mod+Shift+o mode $mode_goto_window
bindsym $mod+Shift+comma mode $mode_goto_window
bindsym $mod+Control+m exec i3-input -F 'mark %s' -P 'Mark as: '
bindsym $mod+Control+o exec i3-input -F '[con_mark=%s] focus' -P 'Goto mark: '
bindsym $mod+comma exec i3-input -F '[con_mark=%s] focus' -P 'Goto mark: '

# rename workspace
bindsym $mod+$Alt+b exec i3-input -F 'rename workspace to "%s"' -P 'Rename workspace to: '

# rename window
bindsym $mod+Control+b exec i3-input -F 'title_format "<b>[%s]</b>   %title"' -P 'Window [tag]: '

# move focused window
bindsym $mod+Shift+s move left
bindsym $mod+Shift+n move down
bindsym $mod+Shift+r move up
bindsym $mod+Shift+t move right
bindsym $mod+Shift+Left move left 100
bindsym $mod+Shift+Down move down 100
bindsym $mod+Shift+Up move up 100
bindsym $mod+Shift+Right move right 100
bindsym $mod+b move scratchpad
bindsym $mod+Shift+b scratchpad show
bindsym $mod+Shift+Escape move container to workspace back_and_forth; workspace back_and_forth
bindsym $mod+Shift+Tab move container to workspace back_and_forth; workspace back_and_forth

bindsym $mod+Control+Next move workspace to output right
bindsym $mod+Control+Prior move workspace to output left

bindsym $mod+Shift+Control+s move workspace to output left
bindsym $mod+Shift+Control+n move workspace to output down
bindsym $mod+Shift+Control+r move workspace to output up
bindsym $mod+Shift+Control+t move workspace to output right
bindsym $mod+Shift+Control+Left move workspace to output left
bindsym $mod+Shift+Control+Right move workspace to output right
bindsym $mod+Shift+Control+Up move workspace to output up
bindsym $mod+Shift+Control+Down move workspace to output down

bindsym $mod+Control+s focus output left
bindsym $mod+Control+n focus output down
bindsym $mod+Control+r focus output up
bindsym $mod+Control+t focus output right
bindsym $mod+Control+Left focus output left
bindsym $mod+Control+Down focus output down
bindsym $mod+Control+Up focus output up
bindsym $mod+Control+Right focus output right

# next splits
bindsym $mod+k split h
bindsym $mod+p split v

# layouts
bindsym $mod+e fullscreen
bindsym $mod+i layout stacking
bindsym $mod+v layout tabbed
bindsym $mod+l layout toggle split

# floating
bindsym $mod+space floating toggle
bindsym $Alt+Escape focus mode_toggle
bindsym $Alt+Tab focus mode_toggle

# switch to workspace
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace number $ws5
