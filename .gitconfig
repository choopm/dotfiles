;  vim: set ts=2 sw=2 tw=0 et :
[user]
  name = Christoph Hoopmann
  email = choopm@0pointer.org
  signingkey = AB689BB7
[push]
  default = simple
[core]
  autocrlf = input
  safecrlf = false
  editor = vim
[alias]
  co = checkout
  ci = commit
  st = status -sb
  br = branch
  lg = log --show-signature
  hist = log --pretty=format:\"%C(auto)%h %ad | %s%d [%an]\" --graph --date=short
  visual = !gitg
  stat = shortlog -sne --no-merges
[merge]
  tool = vimdiff
[diff]
  tool = vimdiff
[pull]
  rebase = false
[url "ssh://git@gitlab.0pointer.org:2222/"]
  insteadOf = https://gitlab.0pointer.org/
[url "ssh://git@github.com/"]
  insteadOf = https://github.com/
