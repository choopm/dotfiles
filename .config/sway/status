order += "frame temps"
frame temps {
    format = "{output}{button}"
    format_separator = ' '
    format_button_closed = "  "
    format_button_open = " "
    open = false

    #cpu_usage {
    #    format = " %usage"
    #}

    #cpu_temperature 0 {
    #    format = " %degrees°C"
    #    max_threshold = 80
    #}

    loadavg {
        #format = " i%1min %5min %15min"
        format = ' [\?color=1avg {1min}] [\?color=5avg {5min}] [\?color=15avg {15min}]'
        max_threshold = "4,1"
        on_click 1 = "refresh"
    }

    lm_sensors {
        format_chip = '[\?if=name=coretemp-isa-0000 ] '
        format_chip += ' {format_sensor}'
        format_sensor = '\?color=auto.input {input}°C'
        sensors = ['core*']
        on_click 1 = "refresh"
    }

    #sysdata {
    #    format = "{cpu_freq_avg}{cpu_freq_unit} [\?color=cpu {cpu_used_percent}%]"
    #    thresholds = [(0, "white"), (15, "good"), (50, "degraded"), (90, "bad")]
    #    on_click 1 = "refresh"
    #}

    sysdata {
        format = " [\?color=mem {mem_used_percent}%] {mem_used}{mem_unit}"
        thresholds = [(0, "white"), (15, "good"), (40, "degraded"), (65, "bad")]
        on_click 1 = "refresh"
    }
}

order += "frame tools"
frame tools {
    format = "{output}{button}"
    format_separator = ' '
    format_button_closed = "  "
    format_button_open = " "
    open = false

    pomodoro {
        display_bar = True
        format_active = "{ss} [{bar}]"
        format_stopped = "{ss} [{bar}]"
        format_break = "Break #{breakno} {ss}"
        format_break_stopped = "Break #{breakno} {ss}"
        color_bad = white
        timer_pomodoro = 1500
        timer_break = 300
        sound_pomodoro_end = "/usr/share/sounds/freedesktop/stereo/alarm-clock-elapsed.oga"
        sound_break_end = "/usr/share/sounds/freedesktop/stereo/alarm-clock-elapsed.oga"
    }

    timer {
        format = " {timer}"
        time = 300
        sound = "/usr/share/sounds/freedesktop/stereo/alarm-clock-elapsed.oga"
    }
}

order += "volume master"
volume master {
        format = " %volume"
        format_muted = " (%volume)"
        device = "default"
        mixer = "Master"
        mixer_idx = 0
        on_click 1 = "exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle; exec --no-startup-id killall -USR1 py3status"
        on_click 3 = "exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle; exec --no-startup-id killall -USR1 py3status"
        on_click 4 = "exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%; exec --no-startup-id killall -USR1 py3status"
        on_click 5 = "exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%; exec --no-startup-id killall -USR1 py3status"
}

#order += "backlight"
backlight {
    format = "☼{level}%"
}

order += "battery_level combined"
battery_level combined {
#    battery_id = "all"
    format = "{icon} {percent}% {time_remaining}"
    charging_character = ""
    blocks = ""
    measurement_mode = "sys"
    notify_low_level = True
    hide_seconds = True
    #hide_when_full = True
    threshold_bad = 15
    threshold_degraded = 30
    threshold_full = 95
    on_click 4 = "exec --no-startup-id backlightctl set 10%+"
    on_click 5 = "exec --no-startup-id backlightctl set 10%-"
}

order += "tztime local"
tztime local {
    format = " %a %d.%m %H:%M"
    on_click 4 = "exec --no-startup-id backlightctl set 10%+"
    on_click 5 = "exec --no-startup-id backlightctl set 10%-"
}
