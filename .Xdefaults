! urxvt
URxvt*geometry:         90x28
URxvt*font:             xft:DejaVu Sans Mono for Powerline:style=Book:pixelsize=12
URxvt*letterSpace:      0
URxvt*depth:            32
URxvt*background:       [85]#000000
!URxvt*background:       [80]#dddddd
!URxvt*foreground:       [100]#333333
URxvt*foreground:       [100]#209bd7
URxvt*foreground_bold:	[100]#606b6a
URxvt*borderless:       1
URxvt*scrollBar:        false
URxvt*saveLines:        10000
URxvt*termName:         rxvt
URxvt.perl-ext-common:  default,matcher,clipboard,resize-font,url-select,keyboard-select
URxvt.url-select.launcher:  icecat
URxvt.url-select.underline: true
URxvt.keysym.M-u:           perl:url-select:select_next
URxvt.keysym.M-Escape:      perl:keyboard-select:activate
URxvt.keysym.M-s:           perl:keyboard-select:search
URxvt.keysym.Shift-Control-C:       perl:clipboard:copy
URxvt.keysym.Shift-Control-V:       perl:clipboard:paste
URxvt.clipboard.copycmd:  xsel -ib
URxvt.clipboard.pastecmd: xsel -ob
URxvt.matcher.button:   1
URxvt*.urgentOnBell:    true
URxvt*.shading:         05
URxvt*.transparent:     true
!URxvt*.transparent:     false
URxvt*pointerBlank:     true
URxvt.tabbed.tabbar-fg: 39
URxvt.tabbed.tabbar-bg: 0
URxvt.tabbed.tab-fg:    0
URxvt.tabbed.tab-bg:    39
URxvt.iso14755:         False
! Disable printing the terminal contents when pressing PrintScreen.
URxvt.print-pipe: "cat > /dev/null"

!Xft
Xft.autohint: 0
Xft.antialias: 1
Xft.hinting: true
Xft.hintstyle: hintslight
Xft.dpi: 96
Xft.rgba: rgb
Xft.lcdfilter: lcddefault

!Pnevmal
*color0: #000000
*color8: #555555
*color1: #aa0000
*color9: #ff5555
*color2: #00aa00
*color10: #55ff55
*color3: #aa5500
*color11: #ffff55
*color4: #0000aa
*color12: #5555ff
*color5: #aa00aa
*color13: #ff55ff
*color6: #00aaaa
*color14: #55ffff
*color7: #aaaaaa
*color15: #ffffff

!rofi
rofi.color-enabled: true
rofi.color-window: #393939, #393939, #268bd2
rofi.color-normal: #393939, #ffffff, #393939, #268bd2, #ffffff
rofi.color-active: #393939, #268bd2, #393939, #268bd2, #205171
rofi.color-urgent: #393939, #f3843d, #393939, #268bd2, #ffc39c
rofi.modi: combi,run,drun,ssh,window,windowcd,Goto/Create workspace:~/.scripts/rofi_workspaces.sh
