general {
    colors = true
    interval = 5
    output_format = i3bar
}

order += "async_script usbguard"
async_script usbguard {
    format = "[\?color=orange {output}]"
    script_path = "usbguard-applet.sh"
    force_nocolor = true
    on_click 1 = "exec --no-startup-id usbguard-applet.sh allow"
    on_click 3 = "exec --no-startup-id usbguard-applet.sh reject"
}

order += "frame timewarrior"
frame timewarrior {
    timewarrior {
        format = "[ {format_time}]"
        filter = '1h'

        format_time_separator = ', '

        thresholds = {
            'state_tag': [(0, 'darkgray'), (1, 'degraded')],
            'state_time': [(0, 'darkgray'), (1, 'degraded')],
        }

        on_click 1 = "exec --no-startup-id timew stop"
        on_click 3 = "exec --no-startup-id timew continue"

        cache_timeout = 30
    }
}

order += "frame weather_owm"
frame weather_owm {
    format = "{output}{button}"
    format_separator = ' '
    format_button_closed = "  "
    format_button_open = " "
    open = true

    weather_owm {
        api_key = "77bc2cdafd6b7419092134e16e3702b5"
        city = "Westerstede"
        country = "Germany"
        forecast_days = 0
        unit_rain = "mm"
        unit_snow = "mm"
        unit_temperature = "c"
        unit_wind = "kmh"
