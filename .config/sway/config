assign [class="Steam"] $ws17
assign [title="ROFIOVPN"] $wsvpn

# modes
set $mode_pass_through pass-through
mode "pass-through" {
	bindsym $mod+BackSpace mode "default"
}
bindsym $mod+BackSpace mode "$mode_pass_through"

set $mode_system System (l)ock, (e)xit, (s)uspend, (r)eboot, (p)oweroff
mode "$mode_system" {
    bindsym t exec $screensaver, mode "default"
    bindsym l exit, mode "default"
    bindsym i exec systemctl suspend, mode "default"
    bindsym c exec systemctl reboot, mode "default"
    bindsym q exec systemctl poweroff, mode "default"

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Shift+x mode "$mode_system"

set $mode_resize Resize Window
mode "$mode_resize" {
	bindsym s resize shrink width 1 px or 1 ppt
	bindsym n resize grow height 1 px or 1 ppt
	bindsym r resize shrink height 1 px or 1 ppt
	bindsym t resize grow width 1 px or 1 ppt
	bindsym Left resize shrink width 1 px or 1 ppt
	bindsym Down resize grow height 1 px or 1 ppt
	bindsym Up resize shrink height 1 px or 1 ppt
	bindsym Right resize grow width 1 px or 1 ppt

	bindsym Shift+s resize shrink width 10 px or 10 ppt
	bindsym Shift+n resize grow height 10 px or 10 ppt
	bindsym Shift+r resize shrink height 10 px or 10 ppt
	bindsym Shift+t resize grow width 10 px or 10 ppt
	bindsym Shift+Left resize shrink width 10 px or 10 ppt
	bindsym Shift+Down resize grow height 10 px or 10 ppt
	bindsym Shift+Up resize shrink height 10 px or 10 ppt
	bindsym Shift+Right resize grow width 10 px or 10 ppt

	bindsym Return mode "default"
	bindsym Escape mode "default"
}
bindsym $mod+odiaeresis mode "$mode_resize"

set $mode_mark_window Mark as [0-9]
mode "$mode_mark_window" {
	bindsym 1 mark m1, mode "default"
	bindsym 2 mark m2, mode "default"
	bindsym 3 mark m3, mode "default"
	bindsym 4 mark m4, mode "default"
	bindsym 5 mark m5, mode "default"
	bindsym 6 mark m6, mode "default"
	bindsym 7 mark m7, mode "default"
	bindsym 8 mark m8, mode "default"
	bindsym 9 mark m9, mode "default"
	bindsym 0 mark m0, mode "default"

	bindsym Return mode "default"
	bindsym Escape mode "default"
}

set $mode_goto_window Goto mark [0-9]
mode "$mode_goto_window" {
	bindsym 1 [con_mark="m1"] focus, mode "default"
	bindsym 2 [con_mark="m2"] focus, mode "default"
	bindsym 3 [con_mark="m3"] focus, mode "default"
	bindsym 4 [con_mark="m4"] focus, mode "default"
	bindsym 5 [con_mark="m5"] focus, mode "default"
	bindsym 6 [con_mark="m6"] focus, mode "default"
	bindsym 7 [con_mark="m7"] focus, mode "default"
	bindsym 8 [con_mark="m8"] focus, mode "default"
	bindsym 9 [con_mark="m9"] focus, mode "default"
	bindsym 0 [con_mark="m0"] focus, mode "default"

	bindsym Return mode "default"
	bindsym Escape mode "default"
}

# bars
bindsym $mod+Control+z bar mode toggle bottombar
bindsym $mod bar hidden_state toggle bottombar

bar {
	id bottombar
	position bottom
	#mode hide
	hidden_state hide
	modifier $mod
	workspace_buttons yes
	binding_mode_indicator yes
	strip_workspace_numbers no
	tray_output primary
	status_command $status_command
}
